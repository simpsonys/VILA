{
  "start_patterns": [
    "cmd_from_mockapp",
    "REQUEST OPEN SERVER"
  ],
  "end_patterns": [
    "Process Finished!"
  ],
  "success_patterns": [
    "result_code=success"
  ],
  "clickable_patterns": {
    "conversationId": {
      "pattern": "conversationId\\[([^\\]]+)\\]",
      "url_template": "https://sumologic.bixbydev.com/stg/conversation/?conversationId={value}",
      "display_name": "ConversationID"
    },
    "requestId": {
      "pattern": "requestId\\[([^\\]]+)\\]",
      "url_template": null,
      "display_name": "RequestID"
    }
  },
  "utterance_patterns": {
    "cmd_from_mockapp": {
      "pattern": "cmd_from_mockapp, ([^\\]]+)",
      "utterance": "{value}"
    },
    "kAsr2Response": {
      "pattern": "kAsr2Response \\[FINAL\\] \\[([^\\]]+)\\]",
      "utterance": "{value}"
    }
  },
  "pattern_groups": {
    "MakeMetaDataParams": {
      "name": "MakeMetaDataParams",
      "patterns": [
        "MakeMetaDataParams.*"
      ]
    },
    "Actions": {
      "name": "Action",
      "patterns": [
		"PROCESS ACTION URL",
        "result_code"
      ]
    }
  }
}