{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "voice-log-analyzer",
  "version": "1.5.1",
  "identifier": "com.vd.voice-log-analyzer",
  "build": {
    "beforeBuildCommand": "node scripts/copy-assets.js",
    "frontendDist": "../dist",
    "devUrl": null
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Voice Log Analyzer",
        "width": 800,
        "height": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
